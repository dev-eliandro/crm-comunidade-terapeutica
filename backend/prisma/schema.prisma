generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String  @id @default(cuid())
  username     String  @unique
  email        String  @unique
  passwordHash String  @map("password_hash")
  resetToken   String? @map("reset_token")

  @@map("users")
}

model Resident {
  id String @id @default(cuid())

  status String?
  progressoPorcentagem Int?

  solicitanteEquipamento String?
  solicitanteMunicipio String?
  solicitanteResponsavel String?
  solicitanteData DateTime?

  usuarioNome String
  usuarioNomeSocial String?
  usuarioDataNascimento DateTime?
  usuarioNaturalidade String?
  usuarioFiliacao String?
  usuarioEstadoCivil String?

  usuarioCPF String @unique
  usuarioRG String?

  usuarioSexoBiologico String?
  usuarioIdentidadeGenero String?
  usuarioPossuiCadastroUnico String?

  usuarioEndereco String?
  usuarioNumero String?
  usuarioBairro String?
  usuarioTelefone String?

  usuarioSituacaoMoradia String?
  usuarioTipoResidencia String?
  usuarioPerfilDeficiencia String?

  rendaPossui String?
  rendaValor String?
  rendaProfissao String?
  rendaRecebeBeneficio String?
  rendaRecebeBeneficioQual String?

  termoAdesaoNome String?
  termoAdesaoData DateTime?

  relatoCaso String?

  saudeMedicoNome String?
  saudeMedicoCRM String?
  saudeCID String?
  saudeDataAvaliacao DateTime?
  saudeApto String?

  prontuarioRG String?
  prontuarioRendaMensal String?
  prontuarioDataIngresso DateTime?
  prontuarioDataPrevistaTermino DateTime?

  prontuarioResponsavelTecnicoNome String?
  prontuarioResponsavelTecnicoRegistro String?
  prontuarioResponsavelTecnicoData DateTime?

  psaMotivoBusca String?
  psaHistoriaProblemaAtualUltimoUso String?
  psaTentativasAnterioresAbstinencia String?

  psaGastoMedioSubstancias String?
  psaObjetivosGerais String?

  psaIntervencoesAtendimentosTerapeuticos String?
  psaIntervencoesAtividadesEducativas String?
  psaIntervencoesAcompanhamentoPsicologico String?
  psaIntervencoesOutras String?

  psaCriteriosAcompanhamento String?

  psaExamesAnexados String?
  psaLaudosAnexados String?

  ocorrenciasEvasao String?
  ocorrenciasAcidentes String?
  ocorrenciasGerais String?

  responsavelPsicologoNome String?
  responsavelPsicologoCRP String?
  responsavelPsicologoData DateTime?

  responsavelAssistenteSocialNome String?
  responsavelAssistenteSocialCRESS String?
  responsavelAssistenteSocialData DateTime?

  // Campos compostos/listas do prontuário (rede de apoio, familiares, atividades,
  // intercorrências, saídas, frequência, histórico de substâncias, evoluções,
  // comunicações com família, medicações, etc.) guardados como JSON para preservar
  // fidelidade total com o formulário do frontend sem precisar de uma tabela por seção.
  dadosCompletos Json? @map("dados_completos")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  medicationLogs MedicationLog[]

  @@map("residents")
}

model MedicationLog {
  id               String    @id @default(cuid())
  residentId       String    @map("resident_id")
  resident         Resident  @relation(fields: [residentId], references: [id], onDelete: Cascade)

  medicationId     String    @map("medication_id")
  medicationNome   String    @map("medication_nome")
  dosagem          String?
  horarioPrevisto  String    @map("horario_previsto")
  horarioRealizado String?   @map("horario_realizado")
  status           String
  administradoPor  String?   @map("administrado_por")
  alertasAtivos    Boolean?  @map("alertas_ativos")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("medication_logs")
}
