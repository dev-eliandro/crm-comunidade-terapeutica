{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:all": "concurrently \"npm run dev\" \"node server.js\"",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "package:win": "pkg installer.js --targets node18-win-x64 --output dist/crm-installer.exe"
  },
  "pkg": {
    "scripts": [
      "server.js",
      "db.js",
      "installer.js"
    ],
    "assets": [
      "dist/**",
      "node_modules/sqlite3/lib/binding/napi-v6-linux-x64/node_sqlite3.node",
      "node_modules/sqlite3/lib/binding/napi-v6-win32-x64/node_sqlite3.node"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "output": "dist/crm-installer.exe"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^10.0.3",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "sqlite3": "^6.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "pkg": "^5.8.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
